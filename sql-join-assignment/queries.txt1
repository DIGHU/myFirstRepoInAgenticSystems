-- Create users table
CREATE TABLE users (
    user_id INTEGER PRIMARY KEY,
    name TEXT,
    signup_date DATE
);

-- Create orders table
CREATE TABLE orders (
    order_id INTEGER PRIMARY KEY,
    user_id INTEGER,
    amount INTEGER,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

-- Create activity table
CREATE TABLE activity (
    user_id INTEGER,
    login_count INTEGER,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

